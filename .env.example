# ── Supabase (Project Settings → API) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role   # server-only, never exposed

# ── Admin allowlist (the ONLY email allowed into /admin) ───────────────────
ADMIN_EMAIL=euginemicah@gmail.com

# ── Control Room allowlist (comma-separated emails allowed into /control-room)
# Separate surface from /admin above -- no coupling. Also union'd at runtime
# with the cms_admin_emails table (supabase/migrations/002_site_rebuild.sql)
# so admins can be added/removed without a redeploy. Requires the Google
# provider to be enabled in the Supabase dashboard (Authentication > Providers)
# with a real Google Cloud OAuth client -- owner-only setup, see lib/cms-auth.ts.
CMS_ADMIN_EMAILS=euginemicah@gmail.com

# ── LinkedIn app (developer.linkedin.com — see FINAL_CHECKLIST.md) ─────────
LINKEDIN_CLIENT_ID=TODO_paste_from_linkedin_developer_app
LINKEDIN_CLIENT_SECRET=TODO_paste_from_linkedin_developer_app

# ── Site + cron ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://euginemicah.tech
CRON_SECRET=TODO_generate_a_long_random_string   # Vercel sends this to /api/cron/*

# ── Paystack (dashboard.paystack.com → Settings → API Keys & Webhooks) ─────
# Real checkout for /book. Register the webhook URL in the Paystack
# dashboard: https://euginemicah.tech/api/paystack-webhook, event: charge.success
PAYSTACK_SECRET_KEY=TODO_paste_live_secret_key
